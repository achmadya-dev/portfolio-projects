{
  "name": "portfolio-projects",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "bun run --bun vite dev --force",
    "build": "bun run --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "bun:build": "bun run --bun vite build --config vite.bun.config.ts",
    "bun:start": "bun run --bun backend.ts",
    "db:push": "bun --env-file=.env drizzle-kit push",
    "email:dev": "email dev --dir src/components/emails --port 5555",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "bunx --bun auth generate --config ./src/lib/auth/auth.ts --output ./src/lib/db/schema/auth.ts",
    "add-ui-components": "bunx --bun shadcn@latest add",
    "shadcn-mcp": "bunx shadcn mcp init ",
    "tsc": "bunx tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "docker:build": "docker build -t tanstack-start-app .",
    "docker:run": "docker run -p 3000:3000 --env-file .env tanstack-start-app",
    "docker:storage": "dotenv -e .env -- bash scripts/start-docker.sh",
    "upload:s3": "bun run --env-file=.env scripts/upload-to-s3.ts",
    "redis:start": "bash scripts/redis.sh start",
    "redis:stop": "bash scripts/redis.sh stop",
    "redis:status": "bash scripts/redis.sh status",
    "redis:logs": "bash scripts/redis.sh logs",
    "test:db": "vitest run src/lib/db/rls.test.ts",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "bun:update": "bun update --latest"
  },
